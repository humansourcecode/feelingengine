# Feeling Engine — Environment Configuration
# Copy this file to .env and fill in your own API keys.
# Each service is YOUR account — Feeling Engine does not proxy or store your keys.

# ============================================================
# LLM — for the brain-to-emotion synthesis layer
# Choose ONE (Claude recommended for highest quality)
# ============================================================
ANTHROPIC_API_KEY=your_anthropic_key_here
# GOOGLE_AI_API_KEY=your_google_ai_key_here    # alternative: Gemini

# ============================================================
# Text-to-Speech — for converting text content to audio
# Required only when analyzing TEXT content (not needed for audio/video)
# ============================================================
ELEVENLABS_API_KEY=your_elevenlabs_key_here
# ELEVENLABS_VOICE_ID=optional_specific_voice_id

# ============================================================
# GPU Compute — for running TRIBE v2 brain predictions
# ============================================================
# Modal (recommended — serverless, pay-per-use)
MODAL_TOKEN_ID=your_modal_token_id
MODAL_TOKEN_SECRET=your_modal_token_secret

# HuggingFace — required for TRIBE v2 model weight downloads
HUGGINGFACE_ACCESS_TOKEN=your_hf_token_here

# ============================================================
# Modal auth note
# ============================================================
# You can also authenticate Modal via `modal setup` (stored in ~/.modal.toml)
# instead of the MODAL_TOKEN_* env vars above. Either works.
